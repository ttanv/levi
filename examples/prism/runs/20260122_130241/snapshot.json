      "cell_index": 0,
      "program_id": "57508bd9-4d9f-41e1-9e46-495e3b0d75ad",
      "code": "\"\"\"PRISM: GPU Model Placement Optimizer.\"\"\"\n\nfrom dataclasses import dataclass\n\nGPU_MEM_SIZE = 80  # GB\n\n@dataclass\nclass Model:\n    model_name: str\n    model_size: int\n    req_rate: int\n    slo: int\n    cur_gpu_id: int\n\n\ndef compute_model_placement(gpu_num, models):\n    \"\"\"\n    Compute a model placement that minimizes the maximum KVPR across all GPUs.\n\n    Args:\n        gpu_num: Number of GPUs\n        models: List of models to place\n\n    Returns:\n        A placement of models to GPUs\n    \"\"\"\n\n    # Enhanced greedy placement with post-processing to balance load\n    # 1) Sort models by r_j / s_j in descending order (critical for greedy)\n    sorted_models = sorted(models, key=lambda m: (m.req_rate / m.slo), reverse=True)\n\n    # 2) Initialize per-GPU states\n    placement = {gpu_id: [] for gpu_id in range(gpu_num)}\n    shared_kv = [GPU_MEM_SIZE for _ in range(gpu_num)]  # remaining memory per GPU\n    weighted_req_rate = [0.0 for _ in range(gpu_num)]   # sum of r_j / s_j per GPU\n\n    # 3) Assign each model greedily to minimize KVPR\n    for model in sorted_models:\n        best_idx = None\n        best_ratio = float('inf')\n\n        # Try all GPUs to find the one that minimizes KVPR after placement\n        for gpu_id in range(gpu_num):\n            if model.model_size <= shared_kv[gpu_id] and shared_kv[gpu_id] > 0:\n                new_weighted = weighted_req_rate[gpu_id] + model.req_rate / model.slo\n                new_remaining = shared_kv[gpu_id] - model.model_size\n                if new_remaining <= 0:\n                    continue\n                new_ratio = new_weighted / new_remaining\n                if new_ratio < best_ratio:\n                    best_ratio = new_ratio\n                    best_idx = gpu_id\n\n        if best_idx is None:\n            # Fallback: place on first available GPU even if it reduces balance\n            for gpu_id in range(gpu_num):\n                if model.model_size <= shared_kv[gpu_id]:\n                    best_idx = gpu_id\n                    break\n            if best_idx is None:\n                raise ValueError(\n                    f\"Unable to place model of size {model.model_size} GB on any GPU. \"\n                    f\"Remaining per-GPU memory: {shared_kv}\"\n                )\n\n        placement[best_idx].append(model)\n        weighted_req_rate[best_idx] += model.req_rate / model.slo\n        shared_kv[best_idx] -= model.model_size\n\n    # 4) Post-processing: improve load balance by moving models between GPUs\n    # Focus on high-weight models (high r/slo) for better impact\n    for _ in range(100):  # increase iterations for better convergence\n        improved = False\n        # Sort models by weight (r/slo) in descending order for prioritized movement\n        model_candidates = []\n        for gpu_id in range(gpu_num):\n            for model in placement[gpu_id]:\n                model_candidates.append((model.req_rate / model.slo, model, gpu_id))\n        model_candidates.sort(reverse=True)  # prioritize high-weight models\n\n        for _, model, gpu_id in model_candidates:\n            # Try moving model to another GPU\n            for other_gpu in range(gpu_num):\n                if other_gpu == gpu_id:\n                    continue\n                # Check if moving is possible\n                if model.model_size > shared_kv[other_gpu]:\n                    continue\n                # Compute current and new KVPRs\n                old_weighted_gpu = weighted_req_rate[gpu_id]\n                new_weighted_gpu = old_weighted_gpu - model.req_rate / model.slo\n                new_weighted_other = weighted_req_rate[other_gpu] + model.req_rate / model.slo\n                old_remaining_gpu = shared_kv[gpu_id]\n                new_remaining_gpu = old_remaining_gpu + model.model_size\n                new_remaining_other = shared_kv[other_gpu] - model.model_size\n                if new_remaining_gpu <= 0 or new_remaining_other <= 0:\n                    continue\n                old_kvpr_gpu = old_weighted_gpu / old_remaining_gpu if old_remaining_gpu > 0 else 0\n                new_kvpr_gpu = new_weighted_gpu / new_remaining_gpu\n                new_kvpr_other = new_weighted_other / new_remaining_other\n                # Check if moving reduces max KVPR\n                if max(new_kvpr_gpu, new_kvpr_other) < max(old_kvpr_gpu, weighted_req_rate[other_gpu] / shared_kv[other_gpu]):\n                    # Move the model\n                    placement[gpu_id].remove(model)\n                    placement[other_gpu].append(model)\n                    weighted_req_rate[gpu_id] = new_weighted_gpu\n                    weighted_req_rate[other_gpu] = new_weighted_other\n                    shared_kv[gpu_id] = new_remaining_gpu\n                    shared_kv[other_gpu] = new_remaining_other\n                    improved = True\n                    break\n            if improved:\n                break\n        if not improved:\n            break\n\n    return placement\n",
